// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}


/* =============== Enums =============== */
enum FieldPlanStatus {
  PLANNED
  ACTIVE
  COMPLETED
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  CANCELLED
}

enum LeaseModelType {
  STANDARD
  HYBRID
}

/* =============== Farmer =============== */
model Farmer {
  farmerId    String  @id @default(uuid())
  email       String  @unique                 // ✅ login/register: email required & unique
  password    String                          // ✅ login/register: password required
  username    String                          // optional profile fields
  fullName    String?
  phoneNumber String?
  address     String?

  fields      Field[]
  orders      Order[]
}

/* =============== Field =============== */
model Field {
  fieldId        String   @id @default(uuid())
  farmerId       String
  landImage      String?
  landType       String?
  currentCrop    String?
  soilType       String?
  surveyNumber   Int?
  acres          Decimal? @db.Decimal(10, 2)
  irrigationType String?

  farmer         Farmer   @relation(fields: [farmerId], references: [farmerId])
  plans          FieldSeasonPlan[]
  recommendations Recommendation[]
  snapshots      FieldSnapshot[]
  leases         Lease[]
}

/* =============== Crop =============== */
model Crop {
  cropId   String @id @default(uuid())
  name     String
  category String?

  plans           FieldSeasonPlan[]
  recommendedBy   Recommendation[] @relation("RecommendedCrop")
}

/* =============== Season =============== */
model Season {
  seasonId  String   @id @default(uuid())
  name      String
  startDate DateTime
  endDate   DateTime

  plans           FieldSeasonPlan[]
  recommendations Recommendation[]
}

/* =============== FieldSeasonPlan =============== */
model FieldSeasonPlan {
  planId        String          @id @default(uuid())
  fieldId       String
  seasonId      String
  cropId        String
  expectedYield Decimal?        @db.Decimal(12, 2)
  expectedCost  Decimal?        @db.Decimal(12, 2)
  status        FieldPlanStatus

  field   Field  @relation(fields: [fieldId], references: [fieldId])
  season  Season @relation(fields: [seasonId], references: [seasonId])
  crop    Crop   @relation(fields: [cropId], references: [cropId])
}

/* =============== Recommendation =============== */
model Recommendation {
  recommendationId  String   @id @default(uuid())
  fieldId           String
  seasonId          String
  recommendedCropId String
  rationaleJson     Json
  generatedAt       DateTime

  field            Field @relation(fields: [fieldId], references: [fieldId])
  season           Season @relation(fields: [seasonId], references: [seasonId])
  recommendedCrop  Crop   @relation("RecommendedCrop", fields: [recommendedCropId], references: [cropId])
}

/* =============== Product =============== */
model Product {
  productId String  @id @default(uuid())
  name      String
  category  String?
  unit      String?
  price     Decimal @db.Decimal(12, 2)
  stock     Int

  orderItems OrderItem[]
}

/* =============== Order =============== */
model Order {
  orderId  String      @id @default(uuid())
  farmerId String
  status   OrderStatus
  total    Decimal     @db.Decimal(12, 2)
  placedAt DateTime

  farmer   Farmer      @relation(fields: [farmerId], references: [farmerId])
  items    OrderItem[]
}

/* =============== OrderItem =============== */
model OrderItem {
  orderItemId String  @id @default(uuid())
  orderId     String
  productId   String
  qty         Int
  unitPrice   Decimal @db.Decimal(12, 2)

  order   Order   @relation(fields: [orderId], references: [orderId])
  product Product @relation(fields: [productId], references: [productId])
}

/* =============== FieldSnapshot (optional) =============== */
model FieldSnapshot {
  snapshotId  String   @id @default(uuid())
  fieldId     String
  at          DateTime
  avgMoisture Float?
  lastPh      Float?
  soilTemp    Float?
  notes       String?

  field       Field    @relation(fields: [fieldId], references: [fieldId])
}

/* =============== Lease =============== */
model Lease {
  leaseId        String        @id @default(uuid())
  fieldId        String
  modelType      LeaseModelType
  profitSharePct Decimal?      @db.Decimal(5, 2)
  rentAmount     Decimal       @db.Decimal(12, 2)
  startDate      DateTime
  endDate        DateTime?
  status         String

  field          Field         @relation(fields: [fieldId], references: [fieldId])
}
