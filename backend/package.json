{
  "name": "backend",
  "version": "1.0.0",
  "description": "A Farmer Project",
  "license": "ISC",
  "author": "Bharath",
  "main": "index.ts",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "studio": "prisma studio",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "prisma:generate": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "migrate:dev:named": "prisma migrate dev --name init",
    "migrate:deploy": "prisma migrate deploy",
    "seed:admin": "ts-node prisma/seed.admin.ts",
    "seed:snapshots": "ts-node prisma/seed.snapshots.ts",
    "seed:recos": "ts-node prisma/seed.recos.ts",
    "check:type": "tsc --noEmit",
    "check:lint": "eslint . --ext .ts",
    "test": "echo \"(no tests yet)\" && exit 0",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.admin.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@prisma/client": "^6.17.1",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^6.17.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
